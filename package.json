{
  "name": "cashflow-forecaster",
  "version": "1.0.0",
  "private": true,
  "description": "ForecastOS — AI-powered cash flow projections for small businesses",
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "install:all": "npm install && npm install --prefix server && npm install --prefix client",
    "postinstall": "npm install --prefix server && npm install --prefix client",
    "dev": "concurrently -n server,client -c cyan,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm run dev --prefix server",
    "dev:client": "npm run dev --prefix client",
    "seed": "npm run seed --prefix server",
    "build": "npm run build --prefix client",
    "start": "npm run start --prefix server",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"{server,client}/src/**/*.{js,jsx,css}\" \"server/test/**/*.js\"",
    "format:check": "prettier --check \"{server,client}/src/**/*.{js,jsx,css}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^9.1.0",
    "puppeteer-core": "^24.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "shell-quote": "^1.8.4"
  }
}
