# Copy this file to .env and fill in your values.
# The app runs fully WITHOUT an API key (it falls back to built-in template insights).
# Add a key to get real Claude-generated narratives and recommendations.

# Your Anthropic API key (optional). Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Secret used to sign JWTs. Change this to any long random string in production.
JWT_SECRET=dev-secret-change-me-in-production

# Port the Express API listens on (the Vite dev server proxies /api to this).
PORT=4000

# Set to "production" to enable production guardrails: the server refuses to
# start unless JWT_SECRET and ENCRYPTION_KEY are set to strong (non-default)
# values. Leave unset/"development" for local dev.
NODE_ENV=development

# Comma-separated allowlist of origins the API accepts (CORS). Leave blank in
# dev (Vite proxies same-origin). In prod set e.g. https://app.yourdomain.com
CORS_ORIGIN=

# Optional override for the SQLite file location. Defaults to server/data/app.db.
# Tests use ':memory:'. Production can point this elsewhere.
DATABASE_PATH=

# --- Live bank data via Plaid (optional) ---
# Get FREE sandbox keys at https://dashboard.plaid.com → Developers → Keys.
# Without these, the "Connect a bank" button shows a notice and the app still
# works with demo data / manual entry.
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_COUNTRY_CODES=US
PLAID_PRODUCTS=transactions
# Only needed for true push webhooks when deployed behind a public URL (e.g. an
# ngrok tunnel). Leave blank for local dev — use "Sync now" / polling instead.
PLAID_WEBHOOK_URL=

# 32-byte secret used to encrypt stored bank access tokens. Falls back to a hash
# of JWT_SECRET if unset. Set a strong random value in production.
ENCRYPTION_KEY=

# --- SMS alerts via Twilio (optional) ---
# Without these, SMS runs in SIMULATION mode: messages are logged to the server
# console (and the verification code is returned to the UI) so the full flow is
# testable with no Twilio account.
#
# TESTING: use Twilio TEST credentials (console.twilio.com → "Test Credentials")
# with magic number +15005550006 for TWILIO_PHONE_NUMBER — no real SMS is sent.
# PRODUCTION: swap in your LIVE Account SID (AC...), Auth Token, and a real
# Messaging-capable Twilio number (E.164, e.g. +14155551234).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Public base URL used in SMS deep links (the "View details" link).
APP_URL=http://localhost:5173
